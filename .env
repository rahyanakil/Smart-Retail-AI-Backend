# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL (production-ready, serverless)
DATABASE_URL="postgresql://neondb_owner:npg_7MgWhVLqwrm4@ep-lingering-tooth-aqdc5rp1-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="super-secret-jwt-key-change-this-in-production-please"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# In dev, any localhost:* is allowed automatically — this value is only used in production.
# Comma-separate multiple origins: http://app.example.com,https://app.example.com
FRONTEND_URL="http://localhost:3000"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

