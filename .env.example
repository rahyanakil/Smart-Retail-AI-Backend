# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL — get your connection string from https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use: openssl rand -base64 48
JWT_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production frontend URL (comma-separated for multiple origins)
FRONTEND_URL="https://your-app.vercel.app"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
