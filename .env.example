# ─────────────────────────────────────────────────────────────
#  SmartRetail AI  — Backend Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit the real .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Neon PostgreSQL — get your string at https://console.neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-strong-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-different-strong-secret-min-32-chars"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Production: your Vercel frontend URL (comma-separated for multiple)
# e.g. https://smartretail-ai.vercel.app,https://yourdomain.com
FRONTEND_URL="http://localhost:3000"

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── AI (Google Gemini) ────────────────────────────────────────
# Get free keys at: https://aistudio.google.com/app/apikey
# Each key = separate Google project = its own 15 RPM free quota.
# Keys rotate round-robin; if one is exhausted the next is tried automatically.
#
#   1 key  → 15 RPM effective
#   2 keys → 30 RPM effective
#   3 keys → 45 RPM effective
#
GEMINI_API_KEY="your-primary-api-key"
GEMINI_API_KEY_1="your-second-api-key"    # optional — doubles quota
GEMINI_API_KEY_2="your-third-api-key"     # optional — triples quota

# Model — gemini-2.0-flash-lite has 30 RPM free (2x), good for analytics
# GEMINI_MODEL=gemini-2.0-flash          # default
# GEMINI_MODEL=gemini-2.0-flash-lite     # 30 RPM free — try this first
